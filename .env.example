# Copy to .env and adjust. All keys map 1:1 to AppConfig — nested fields use `__`.

# Server
MAILIFY_SERVER__HOST=0.0.0.0
MAILIFY_SERVER__PORT=8080

# Database
MAILIFY_DATABASE__URL=postgres://mailify:mailify@localhost:5432/mailify
MAILIFY_DATABASE__MAX_CONNECTIONS=10

# SMTP (default sender — can be overridden per request via /mail/send-custom)
MAILIFY_SMTP__HOST=localhost
MAILIFY_SMTP__PORT=1025
MAILIFY_SMTP__TLS=none
MAILIFY_SMTP__DEFAULT_FROM_EMAIL=no-reply@example.com
MAILIFY_SMTP__DEFAULT_FROM_NAME=Mailify

# Auth — GENERATE A STRONG SECRET IN PRODUCTION
MAILIFY_AUTH__JWT_SECRET=CHANGE_ME_IN_PRODUCTION
MAILIFY_AUTH__JWT_ISSUER=mailify
MAILIFY_AUTH__JWT_TTL_SECS=3600

# Queue workers
MAILIFY_QUEUE__WORKER_CONCURRENCY=4
MAILIFY_QUEUE__MAX_RETRIES=5

# Templates
MAILIFY_TEMPLATES__PATH=./templates-parser/out
MAILIFY_TEMPLATES__STRICT=false

# i18n
MAILIFY_I18N__DEFAULT_LOCALE=en
MAILIFY_I18N__SUPPORTED_LOCALES=["en","fr"]

# Theme (examples — full schema in crates/mailify-config/src/theme.rs)
MAILIFY_THEME__BRAND_NAME=Acme
MAILIFY_THEME__BRAND_LOGO_URL=https://example.com/logo.png
MAILIFY_THEME__COLORS__PRIMARY=#2563eb
MAILIFY_THEME__COLORS__PRIMARY_FOREGROUND=#ffffff

# Observability
MAILIFY_OBSERVABILITY__LOG_LEVEL=info
MAILIFY_OBSERVABILITY__LOG_FORMAT=pretty
RUST_LOG=info,mailify=debug
