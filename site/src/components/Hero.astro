---
---

<section class="hero relative overflow-hidden py-12 lg:pb-24">
  <div
    class="mx-auto grid w-[min(100%-2rem,var(--container-wide))] items-center gap-12 lg:grid-cols-[minmax(0,1.1fr)_minmax(22rem,30rem)]"
  >
    <div>
      <p
        class="mb-6 inline-flex rounded-full bg-brand-primary-muted px-3 py-1 font-display text-xs font-semibold uppercase tracking-wider text-brand-primary"
      >
        Self-hosted · Theme-aware · Rust-fast
      </p>

      <h1
        class="m-0 max-w-[11ch] font-display font-semibold leading-[1.02] tracking-tighter text-ink-900"
        style="font-size: clamp(var(--text-2xl), 8vw, var(--text-4xl));"
      >
        The mail server that wears your brand.
      </h1>

      <p class="mt-6 max-w-xl text-md text-ink-500">
        Self-hosted transactional mail with your colors, your templates, and your SMTP provider.
        One Docker image. Zero vendor lock-in.
      </p>

      <div class="mt-8 flex flex-wrap items-center gap-4">
        <a
          class="inline-flex items-center gap-2 rounded-md bg-brand-primary px-6 py-3 font-display text-sm font-medium text-white transition hover:bg-brand-primary-hover"
          href="/docs/getting-started/installation"
        >
          Get started →
        </a>
        <code
          class="inline-flex min-h-12 items-center rounded-full border border-border bg-paper-raised/85 px-4 py-3 font-mono text-sm text-ink-900"
          aria-label="Docker pull command"
        >
          docker pull donighost/mailify
        </code>
      </div>

      <ul class="mt-8 grid gap-3 p-0 text-ink-500 list-none">
        <li class="flex items-baseline gap-3">
          <span aria-hidden class="size-2 shrink-0 translate-y-1 rounded-full bg-brand-accent"></span>
          Branded emails from config-driven theme tokens
        </li>
        <li class="flex items-baseline gap-3">
          <span aria-hidden class="size-2 shrink-0 translate-y-1 rounded-full bg-brand-accent"></span>
          Per-job SMTP override for multi-tenant setups
        </li>
        <li class="flex items-baseline gap-3">
          <span aria-hidden class="size-2 shrink-0 translate-y-1 rounded-full bg-brand-accent"></span>
          Compiled React Email templates with a durable queue
        </li>
      </ul>
    </div>

    <div class="visual relative grid min-h-96 place-items-center" aria-hidden="true">
      <div
        class="orb orb-primary absolute right-8 top-0 size-48 rounded-full opacity-80 blur-2xl"
      ></div>
      <div
        class="orb orb-accent absolute bottom-4 left-8 size-36 rounded-full opacity-80 blur-2xl"
      ></div>

      <svg viewBox="0 0 520 420" class="hero-svg relative z-10 w-[min(100%,32rem)] drop-shadow-xl">
        <defs>
          <linearGradient id="mailify-surface" x1="0" y1="0" x2="1" y2="1">
            <stop offset="0%" stop-color="var(--bg-raised)" />
            <stop offset="100%" stop-color="color-mix(in srgb, var(--brand-primary-muted) 55%, var(--bg-raised))" />
          </linearGradient>
        </defs>
        <rect x="78" y="76" width="272" height="210" rx="28" fill="url(#mailify-surface)" stroke="var(--border)" stroke-width="2" />
        <path d="M108 114L207.758 189.773C210.704 192.012 214.766 192.012 217.712 189.773L318 114" stroke="var(--brand-primary)" stroke-width="12" stroke-linecap="round" stroke-linejoin="round" />
        <path d="M282 76H354C370.569 76 384 89.4315 384 106V181" stroke="var(--brand-accent)" stroke-width="12" stroke-linecap="round" />
        <path d="M278 138L324 92" stroke="var(--brand-accent)" stroke-width="12" stroke-linecap="round" />
        <rect x="198" y="220" width="190" height="114" rx="24" fill="var(--ink-900)" opacity="0.96" />
        <rect x="222" y="246" width="110" height="16" rx="8" fill="var(--brand-primary)" />
        <rect x="222" y="276" width="126" height="10" rx="5" fill="var(--ink-300)" />
        <rect x="222" y="298" width="84" height="10" rx="5" fill="var(--ink-300)" />
        <rect x="332" y="246" width="34" height="34" rx="10" fill="var(--brand-accent)" />
      </svg>
    </div>
  </div>
</section>

<style>
  .hero {
    background:
      radial-gradient(circle at top left, color-mix(in srgb, var(--brand-primary-muted) 82%, transparent), transparent 34%),
      radial-gradient(circle at 85% 20%, color-mix(in srgb, var(--brand-accent-muted) 65%, transparent), transparent 22%),
      linear-gradient(180deg, color-mix(in srgb, var(--bg-raised) 55%, transparent), transparent 55%);
  }

  .orb-primary {
    background: color-mix(in srgb, var(--brand-primary) 28%, transparent);
  }

  .orb-accent {
    background: color-mix(in srgb, var(--brand-accent) 30%, transparent);
  }
</style>
