---
import Logo from '../assets/logo.svg?raw';

const cols = [
  {
    title: 'Product',
    links: [
      { label: 'Docs', href: '/docs' },
      { label: 'API', href: '/docs/reference/http-api' },
      { label: 'Pricing', href: '/pricing' },
    ],
  },
  {
    title: 'Project',
    links: [
      { label: 'GitHub', href: 'https://github.com/donilite/mailify' },
      { label: 'Roadmap', href: 'https://github.com/donilite/mailify/blob/master/TODO.md' },
      { label: 'Sponsors', href: 'https://github.com/sponsors/donilite' },
    ],
  },
  {
    title: 'Community',
    links: [
      { label: 'Discussions', href: 'https://github.com/donilite/mailify/discussions' },
      { label: 'Issues', href: 'https://github.com/donilite/mailify/issues' },
      { label: 'Contributing', href: '/docs/contributing/overview' },
    ],
  },
];
---

<footer
  class="border-t border-border bg-linear-to-b from-brand-primary-muted/30 to-bg pb-8 pt-16"
>
  <div
    class="mx-auto grid w-[min(100%-2rem,var(--container-wide))] gap-12 lg:grid-cols-[1.25fr_1fr] lg:items-start"
  >
    <div>
      <a
        class="relative inline-flex items-center gap-3 font-display font-semibold text-ink-900"
        href="/"
        aria-label="Mailify home"
      >
        <span
          class="brand-mark inline-flex size-8 text-brand-primary"
          set:html={Logo}
          aria-hidden="true"
        ></span>
        <span class="text-md font-bold tracking-tight">Mailify</span>
      </a>
      <p class="mt-4 max-w-md text-sm text-ink-500">
        The self-hosted transactional email server that wears your brand.
      </p>

      <div class="mt-8 flex flex-wrap items-center gap-3 text-xs text-ink-500">
        <span>MIT-licensed · made in Rust</span>
        <span aria-hidden>·</span>
        <a class="hover:text-ink-900" href="https://github.com/donilite/mailify" rel="noopener">v0.1.2</a>
      </div>
    </div>

    <div class="grid grid-cols-1 gap-8 sm:grid-cols-3">
      {cols.map((col) => (
        <div>
          <h2 class="m-0 mb-4 font-display text-sm font-semibold text-ink-900">{col.title}</h2>
          <ul class="m-0 list-none space-y-3 p-0">
            {col.links.map((link) => (
              <li>
                <a
                  class="block text-sm text-ink-500 transition hover:text-ink-900 focus-visible:text-ink-900"
                  href={link.href}
                  rel={link.href.startsWith('http') ? 'noopener' : undefined}
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</footer>

<style>
  .brand-mark :global(svg) {
    width: 100%;
    height: 100%;
  }
</style>
