---
const crates = [
  'mailify-core',
  'mailify-config',
  'mailify-templates',
  'mailify-smtp',
  'mailify-queue',
  'mailify-auth',
  'mailify-api',
];
---

<section class="py-16 lg:pb-24">
  <div class="mx-auto w-[min(100%-2rem,var(--container-main))]">
    <div class="max-w-2xl">
      <p class="m-0 font-display text-sm font-semibold text-brand-primary">Architecture</p>
      <h2
        class="my-3 font-display font-semibold leading-tight text-ink-900"
        style="font-size: clamp(var(--text-xl), 4vw, var(--text-2xl));"
      >
        Seven crates. One delivery path.
      </h2>
      <p class="m-0 text-ink-500">
        The API layer receives mail requests, auth validates tokens, templates render branded HTML,
        and the queue worker ships through SMTP.
      </p>
    </div>

    <div class="diagram mt-8 grid grid-cols-1 gap-4 md:grid-cols-7 md:items-center">
      {crates.map((crateName, index) => (
        <div
          class:list={[
            'node relative rounded-2xl border border-border bg-paper-raised px-4 py-3 font-mono text-sm text-ink-700',
            index === crates.length - 1 &&
              'border-brand-primary/50 bg-linear-[135deg] from-brand-primary-muted/70 to-paper-raised text-ink-900',
          ]}
        >
          {crateName}
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .node::after {
    content: '';
    position: absolute;
    left: 50%;
    bottom: -1rem;
    width: 1px;
    height: 1rem;
    background: color-mix(in srgb, var(--brand-primary) 35%, var(--border));
  }
  .node:last-child::after {
    display: none;
  }
  @media (min-width: 768px) {
    .node::after {
      left: auto;
      right: -1rem;
      top: 50%;
      bottom: auto;
      width: 1rem;
      height: 1px;
    }
  }
</style>
