---
import ThemeToggle from './ThemeToggle.astro';
import Logo from '../assets/logo.svg?raw';
---

<header
  class="sticky top-0 z-50 border-b border-border/70 bg-bg/80 backdrop-blur-md"
>
  <div
    class="mx-auto grid w-[min(100%-2rem,var(--container-wide))] min-h-16 grid-cols-[auto_1fr_auto] items-center gap-4"
  >
    <a
      class="relative inline-flex items-center gap-3 font-display text-md font-semibold tracking-tight text-ink-900 hover:text-brand-primary"
      href="/"
      aria-label="Mailify home"
    >
      <span
        class="brand-mark inline-flex size-8 text-brand-primary"
        set:html={Logo}
        aria-hidden="true"
      ></span>
      <span class="text-md font-bold tracking-tight">Mailify</span>
    </a>

    <nav
      class="hidden items-center justify-center gap-6 text-sm text-ink-500 lg:inline-flex"
      aria-label="Primary"
    >
      <a class="hover:text-ink-900 focus-visible:text-ink-900" href="/docs">Docs</a>
      <a class="hover:text-ink-900 focus-visible:text-ink-900" href="https://github.com/donilite/mailify" rel="noopener">GitHub</a>
      <a class="hover:text-ink-900 focus-visible:text-ink-900" href="https://github.com/sponsors/donilite" rel="noopener">Sponsors</a>
    </nav>

    <div class="inline-flex items-center justify-end gap-3">
      <ThemeToggle />
      <a
        class="hidden md:inline-flex items-center gap-2 rounded-md bg-brand-primary px-6 py-3 font-display text-sm font-medium text-white transition hover:bg-brand-primary-hover"
        href="/docs/getting-started/installation"
      >
        Get started
      </a>
    </div>
  </div>
</header>

<style>
  .brand-mark :global(svg) {
    width: 100%;
    height: 100%;
  }
</style>
