---
import ThemeToggle from './ThemeToggle.astro';
---

<header class="site-header">
  <div class="shell">
    <a class="brand" href="/" aria-label="Mailify home">
      <img class="logo logo--light" src="/logo.png" alt="Mailify" width="120" height="32" />
      <img class="logo logo--dark" src="/logo-white.png" alt="Mailify" width="120" height="32" />
      <span>Mailify</span>
    </a>

    <nav class="nav" aria-label="Primary">
      <a href="/docs">Docs</a>
      <a href="https://github.com/donilite/mailify">GitHub</a>
      <a href="https://github.com/sponsors/donilite">Sponsors</a>
    </nav>

    <div class="actions">
      <ThemeToggle />
      <a class="btn btn-primary" href="/docs/getting-started/installation">Get started</a>
    </div>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    backdrop-filter: blur(12px);
    background: color-mix(in srgb, var(--bg) 82%, transparent);
    border-bottom: 1px solid color-mix(in srgb, var(--border) 72%, transparent);
  }

  .shell {
    width: min(100% - 2rem, var(--container-wide));
    margin: 0 auto;
    min-height: 4rem;
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: var(--space-4);
  }

  .brand {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: var(--space-3);
    color: var(--text);
    font-family: var(--font-display);
    font-weight: 600;
    letter-spacing: -0.02em;
  }

  .logo {
    height: 2rem;
    width: auto;
  }

  .logo--dark {
    display: none;
  }

  :root[data-theme='dark'] .logo--light {
    display: none;
  }

  :root[data-theme='dark'] .logo--dark {
    display: block;
  }

  .brand span {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .nav {
    display: none;
    align-items: center;
    justify-content: center;
    gap: var(--space-6);
  }

  .nav a {
    color: var(--text-muted);
    font-size: var(--fs-sm);
  }

  .nav a:hover,
  .nav a:focus-visible {
    color: var(--text);
  }

  .actions {
    display: inline-flex;
    justify-content: flex-end;
    align-items: center;
    gap: var(--space-3);
  }

  .actions :global(.btn) {
    display: none;
  }

  @media (min-width: 768px) {
    .actions :global(.btn) {
      display: inline-flex;
    }
  }

  @media (min-width: 1024px) {
    .nav {
      display: inline-flex;
    }
  }
</style>
