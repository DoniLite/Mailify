---
const swatches = [
  { name: 'primary', cssVar: 'var(--brand-primary)' },
  { name: 'accent', cssVar: 'var(--brand-accent)' },
  { name: 'success', cssVar: 'var(--success)' },
];
---

<section class="py-16">
  <div
    class="mx-auto grid w-[min(100%-2rem,var(--container-main))] items-center gap-8 lg:grid-cols-[minmax(0,1fr)_minmax(18rem,26rem)]"
  >
    <div>
      <p class="m-0 font-display text-sm font-semibold text-brand-primary">Theme system</p>
      <h2
        class="my-3 font-display font-semibold leading-tight text-ink-900"
        style="font-size: clamp(var(--text-xl), 4vw, var(--text-2xl));"
      >
        Brand once. Reuse everywhere.
      </h2>
      <p class="m-0 max-w-xl text-ink-500">
        Mailify's default templates read from a theme object at render time, so brand changes stay
        in config instead of leaking into every mail template.
      </p>

      <div class="mt-6 flex flex-wrap gap-4" aria-label="Mailify brand tokens">
        {swatches.map((s) => (
          <div
            class="inline-flex items-center gap-3 rounded-full border border-border bg-paper-raised px-3 py-2"
          >
            <span class="size-4 rounded-full" style={`background:${s.cssVar}`}></span>
            <code class="font-mono text-sm text-ink-700">{s.name}</code>
          </div>
        ))}
      </div>
    </div>

    <div class="grid place-items-center">
      <article
        class="w-[min(100%,28rem)] rounded-3xl border border-border bg-paper-raised p-6 shadow-lg"
      >
        <header class="flex items-center justify-between gap-4">
          <div class="inline-flex items-center gap-3 font-display">
            <span class="inline-flex size-6 items-center justify-center text-brand-primary">
              <svg viewBox="0 0 64 64" fill="none" aria-hidden="true">
                <rect x="6" y="14" width="44" height="36" rx="6" stroke="currentColor" stroke-width="4"/>
                <path d="M10 20 L28 34 Q31 36 34 34 L52 20" stroke="currentColor" stroke-width="4" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
                <path d="M36 24 Q48 22 60 22" stroke="var(--brand-accent)" stroke-width="4" stroke-linecap="round" fill="none"/>
              </svg>
            </span>
            <strong class="font-semibold text-ink-900">Mailify</strong>
          </div>
          <span
            class="rounded-full bg-brand-accent-muted px-3 py-1 font-display text-xs font-semibold uppercase tracking-wider text-brand-accent"
          >
            welcome
          </span>
        </header>

        <h3 class="mt-8 mb-3 font-display text-lg font-semibold text-ink-900">
          Your brand, not your provider.
        </h3>
        <p class="m-0 text-ink-500">
          Swap colors and logo once, then keep shipping the same templates across environments and
          tenants.
        </p>

        <a
          href="/"
          class="mt-8 inline-flex items-center rounded-md bg-brand-primary px-4 py-3 font-display text-sm font-semibold text-white transition hover:bg-brand-primary-hover"
        >
          Open dashboard
        </a>

        <footer
          class="mt-8 flex justify-between gap-4 border-t border-border pt-4 text-xs text-ink-500"
        >
          <span>Primary</span>
          <span>Accent</span>
          <span>Radius</span>
        </footer>
      </article>
    </div>
  </div>
</section>
