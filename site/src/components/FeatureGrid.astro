---
const features = [
  {
    title: 'Branded from config',
    body: 'Theme tokens flow into every render so your mail looks like your product, not like a provider default.',
  },
  {
    title: 'Self-hosted by design',
    body: 'Bring your own SMTP provider, run one Docker image, keep your templates and delivery path under your control.',
  },
  {
    title: 'Templates as code',
    body: 'React Email compiles to HTML ahead of time while minijinja placeholders stay live for runtime variables.',
  },
  {
    title: 'Durable delivery queue',
    body: 'Jobs persist in Postgres through apalis, so a worker restart does not eat your outbound mail.',
  },
  {
    title: 'Multi-tenant friendly',
    body: 'Per-job SMTP override lets one Mailify instance fan out across tenants without leaking shared credentials.',
  },
  {
    title: 'Docs-first ergonomics',
    body: 'Clear config, predictable routes, and CLI helpers keep setup close to a boring infrastructure service.',
  },
];
---

<section class="py-16">
  <div class="mx-auto w-[min(100%-2rem,var(--container-main))]">
    <div class="max-w-3xl">
      <p class="m-0 font-display text-sm font-semibold text-brand-primary">Why Mailify</p>
      <h2
        class="mt-3 max-w-[18ch] font-display font-semibold leading-tight text-ink-900"
        style="font-size: clamp(var(--text-xl), 5vw, var(--text-2xl));"
      >
        Built for developers who want ownership without redoing email infra from scratch.
      </h2>
    </div>

    <div class="mt-8 grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {features.map((feature) => (
        <article
          class="group rounded-lg border border-border bg-paper-raised p-6 transition duration-150 hover:-translate-y-0.5 hover:border-brand-primary/30 hover:shadow-md"
        >
          <div
            class="size-8 rounded-[0.7rem] bg-linear-[135deg] from-brand-primary to-brand-primary/40"
            aria-hidden="true"
          ></div>
          <h3 class="mt-4 mb-3 font-display text-md font-semibold text-ink-900">
            {feature.title}
          </h3>
          <p class="m-0 text-sm text-ink-500">{feature.body}</p>
        </article>
      ))}
    </div>
  </div>
</section>
